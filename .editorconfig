# http://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,jsx,ts,tsx}]
indent_style = tab
indent_size = 4

[*.html]
indent_style = tab
indent_size = 2

[*.{css,scss,sass}]
indent_style = tab
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[*.nix]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.asm]
indent_style = tab
indent_size = 4
